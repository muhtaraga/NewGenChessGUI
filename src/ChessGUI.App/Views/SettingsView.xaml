<UserControl x:Class="ChessGUI.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="1180">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,18,0,8"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Margin="14" VerticalScrollBarVisibility="Auto">
        <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1" CornerRadius="8" Padding="22" MaxWidth="620" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="AYARLAR" Style="{StaticResource HeaderText}" FontSize="20"/>

                <TextBlock Text="Tema" Style="{StaticResource SectionHeader}"/>
                <ComboBox Width="140" HorizontalAlignment="Left" SelectedValue="{Binding SettingsVm.Theme}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="Koyu" Tag="Dark"/>
                    <ComboBoxItem Content="Açık" Tag="Light"/>
                </ComboBox>

                <TextBlock Text="Tahta renkleri" Style="{StaticResource SectionHeader}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Açık kare" Style="{StaticResource MutedText}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SettingsVm.LightSquareColor}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Koyu kare" Style="{StaticResource MutedText}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SettingsVm.DarkSquareColor}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Vurgu" Style="{StaticResource MutedText}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SettingsVm.AccentColor}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Taş / tahta görünümü" Style="{StaticResource SectionHeader}"/>
                <CheckBox Content="Koordinatları göster" IsChecked="{Binding SettingsVm.ShowCoordinates}"
                          Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Taş boyutu" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider Width="180" Minimum="0.7" Maximum="1.3" Value="{Binding SettingsVm.PieceScale}"/>
                </StackPanel>

                <TextBlock Text="Ses ve animasyon" Style="{StaticResource SectionHeader}"/>
                <CheckBox Content="Ses efektleri" IsChecked="{Binding SettingsVm.SoundEnabled}"
                          Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,8"/>
                <CheckBox Content="Taş animasyonu" IsChecked="{Binding SettingsVm.AnimationEnabled}"
                          Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Animasyon süresi (ms)" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding SettingsVm.AnimationDurationMs}"/>
                </StackPanel>

                <TextBlock Text="Davranış" Style="{StaticResource SectionHeader}"/>
                <CheckBox Content="Bilgisayara karşı oynarken tahtayı oto-çevir" IsChecked="{Binding SettingsVm.AutoFlipBoard}"
                          Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,8"/>
                <CheckBox Content="Oyna ve Analiz tahtalarını eşitle (motor-motor maçını canlı izlemek için)"
                          IsChecked="{Binding SettingsVm.SyncPlayAndAnalysisBoards}"
                          Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,8"/>

                <TextBlock Text="Analiz" Style="{StaticResource SectionHeader}"/>
                <CheckBox Content="Analizde motor önerilerini ok ile göster" IsChecked="{Binding SettingsVm.ShowEngineArrows}"
                          Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,8"/>

                <TextBlock Text="Güncellemeler" Style="{StaticResource SectionHeader}"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Güncellemeleri denetle" Command="{Binding SettingsVm.CheckForUpdatesCommand}"
                            IsEnabled="{Binding SettingsVm.IsCheckingForUpdates, Converter={StaticResource InverseBool}}"
                            Width="180" Margin="0,0,8,0"/>
                    <Button Content="İndir ve Kur" Command="{Binding SettingsVm.InstallUpdateCommand}" Width="120"
                            Visibility="{Binding SettingsVm.IsUpdateAvailable, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
                <TextBlock Text="{Binding SettingsVm.UpdateStatusText}" Style="{StaticResource MutedText}" Margin="0,8,0,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <Button Content="Kaydet" Command="{Binding SettingsVm.SaveCommand}" Width="120" Margin="0,0,8,0"/>
                    <Button Content="Varsayılanlara dön" Command="{Binding SettingsVm.ResetDefaultsCommand}" Width="150"/>
                </StackPanel>
                <TextBlock Text="{Binding SettingsVm.StatusText}" Style="{StaticResource MutedText}" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
