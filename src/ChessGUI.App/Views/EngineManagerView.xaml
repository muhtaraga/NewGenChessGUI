<UserControl x:Class="ChessGUI.App.Views.EngineManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ChessGUI.App.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="1180">

    <UserControl.Resources>
        <!-- Seçenek tipine göre editör şablonları -->
        <DataTemplate x:Key="CheckOptionTemplate" DataType="{x:Type vm:OptionEditorViewModel}">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1" IsChecked="{Binding CheckValue}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SpinOptionTemplate" DataType="{x:Type vm:OptionEditorViewModel}">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Name}"/>
                    <TextBlock Style="{StaticResource MutedText}" FontSize="10">
                        <Run Text="min "/><Run Text="{Binding Min, Mode=OneWay}"/>
                        <Run Text=" · max "/><Run Text="{Binding Max, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
                <TextBox Grid.Column="1" Text="{Binding SpinValue}" Height="26" VerticalContentAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ComboOptionTemplate" DataType="{x:Type vm:OptionEditorViewModel}">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Vars}" SelectedItem="{Binding StringValue}"
                          Height="26" VerticalContentAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="StringOptionTemplate" DataType="{x:Type vm:OptionEditorViewModel}">
            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="{Binding Name}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding StringValue}" Height="26" VerticalContentAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ButtonOptionTemplate" DataType="{x:Type vm:OptionEditorViewModel}">
            <Button Content="{Binding Name}" Margin="0,0,0,10" HorizontalAlignment="Left" Padding="12,6"/>
        </DataTemplate>

        <vm:OptionTemplateSelector x:Key="OptionTemplateSelector"
                                   CheckTemplate="{StaticResource CheckOptionTemplate}"
                                   SpinTemplate="{StaticResource SpinOptionTemplate}"
                                   ComboTemplate="{StaticResource ComboOptionTemplate}"
                                   StringTemplate="{StaticResource StringOptionTemplate}"
                                   ButtonTemplate="{StaticResource ButtonOptionTemplate}"/>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sol: motor listesi -->
        <Border Grid.Column="0" Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="MOTORLAR" Style="{StaticResource HeaderText}" FontSize="16" Margin="0,0,0,10"/>

                <ListBox Grid.Row="1" ItemsSource="{Binding EngineManager.Engines}"
                         SelectedItem="{Binding EngineManager.SelectedEngine}"
                         DisplayMemberPath="Name" Background="Transparent" BorderThickness="0"/>

                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                    <Button Content="+ Motor Ekle" Command="{Binding EngineManager.AddEngineCommand}"
                            IsEnabled="{Binding EngineManager.IsAdding, Converter={StaticResource InverseBool}}"/>
                    <Button Content="Kaldır" Command="{Binding EngineManager.RemoveEngineCommand}"/>
                    <TextBlock Text="{Binding EngineManager.StatusText}" Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sağ: seçili motorun UCI seçenek editörü -->
        <Border Grid.Column="1" Margin="14,0,0,0" Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding EngineManager.SelectedEngine.Name}"
                           Style="{StaticResource HeaderText}" FontSize="18" Margin="0,0,0,14"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding EngineManager.OptionEditors}"
                                  ItemTemplateSelector="{StaticResource OptionTemplateSelector}"/>
                </ScrollViewer>

                <Button Grid.Row="2" Content="Kaydet" Command="{Binding EngineManager.SaveCommand}"
                        HorizontalAlignment="Right" Width="120" Margin="0,10,0,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
