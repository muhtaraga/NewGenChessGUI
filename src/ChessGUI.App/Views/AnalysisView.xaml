<UserControl x:Class="ChessGUI.App.Views.AnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ChessGUI.App.Controls"
             xmlns:vm="clr-namespace:ChessGUI.App.ViewModels"
             xmlns:conv="clr-namespace:ChessGUI.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="1180">

    <UserControl.Resources>
        <!-- Kompakt buton (araç çubukları için) -->
        <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="MinWidth" Value="36"/>
        </Style>

        <!-- Hamle listesi jetonu -->
        <DataTemplate x:Key="MoveTokenTemplate" DataType="{x:Type vm:MoveToken}">
            <Border x:Name="bd" Padding="3,1" Margin="1" CornerRadius="3" Background="Transparent" Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.MoveList.NavigateCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                  CommandParameter="{Binding}"/>
                </Border.InputBindings>
                <TextBlock x:Name="txt" Text="{Binding Text}" FontFamily="Consolas" FontSize="13"
                           Foreground="{DynamicResource ForegroundBrush}"/>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsMove}" Value="False">
                    <Setter TargetName="txt" Property="Foreground" Value="{DynamicResource MutedForeground}"/>
                    <Setter TargetName="bd" Property="Cursor" Value="Arrow"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Depth}" Value="1">
                    <Setter TargetName="txt" Property="Foreground" Value="#A6B39A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsComment}" Value="True">
                    <Setter TargetName="txt" Property="FontStyle" Value="Italic"/>
                    <Setter TargetName="txt" Property="Foreground" Value="#7FB07F"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="1">
                    <Setter TargetName="txt" Property="Foreground" Value="#E6C34A"/>
                    <Setter TargetName="txt" Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="2">
                    <Setter TargetName="txt" Property="Foreground" Value="#E28A3C"/>
                    <Setter TargetName="txt" Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="3">
                    <Setter TargetName="txt" Property="Foreground" Value="#E0544B"/>
                    <Setter TargetName="txt" Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter TargetName="txt" Property="Foreground" Value="White"/>
                    <Setter TargetName="txt" Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- Değerlendirme çubuğu -->
        <controls:EvalBar Grid.Column="0" Width="26"
                          WhiteWinProbability="{Binding Engine.WhiteWinProbability}"
                          Caption="{Binding Engine.EvalCaption}"
                          WhiteFavored="{Binding Engine.WhiteFavored}"/>

        <!-- Tahta + oyun raporu şeridi -->
        <Grid Grid.Column="1" Margin="12,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="10">
                <controls:BoardControl DataContext="{Binding Board}"
                                        ShowCoordinates="{Binding DataContext.SettingsVm.ShowCoordinates, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        PieceScale="{Binding DataContext.SettingsVm.PieceScale, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        AnimationEnabled="{Binding DataContext.SettingsVm.AnimationEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        AnimationDurationMs="{Binding DataContext.SettingsVm.AnimationDurationMs, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        LightSquare="{Binding DataContext.SettingsVm.LightSquareColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrush}}"
                                        DarkSquare="{Binding DataContext.SettingsVm.DarkSquareColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrush}}"
                                        ShowEngineArrows="{Binding DataContext.SettingsVm.ShowEngineArrows, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Arrows="{Binding DataContext.Engine.Arrows, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </Border>

            <Border Grid.Row="1" Margin="0,12,0,0" Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding Report.RunCommand}" Margin="0,0,10,0" Padding="12,6">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Content" Value="📋  Oyun raporu"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Report.IsRunning}" Value="True">
                                            <Setter Property="Content" Value="■  Durdur"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock Text="Süre (sn)" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox Width="64" MinHeight="30" ItemsSource="{Binding Report.TimeOptions}"
                                      SelectedItem="{Binding Report.ReportSeconds}"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2" Text="{Binding Report.StatusText}" Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#ECECEC" CornerRadius="4" Padding="7,3" Margin="0,0,6,0">
                                <TextBlock Text="{Binding Report.WhiteAccuracy}" Foreground="#1A1A1A"
                                           FontWeight="SemiBold" FontFamily="Consolas" FontSize="12"/>
                            </Border>
                            <Border Background="#303036" CornerRadius="4" Padding="7,3">
                                <TextBlock Text="{Binding Report.BlackAccuracy}" Foreground="#ECECEC"
                                           FontWeight="SemiBold" FontFamily="Consolas" FontSize="12"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <controls:EvalGraph Height="92" Margin="0,10,0,0"
                                        Points="{Binding Report.GraphPoints}"
                                        CurrentIndex="{Binding Report.CurrentIndex}"
                                        NavigateCommand="{Binding Report.GraphClickCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Sağ panel -->
        <Border Grid.Column="2" Margin="14,0,0,0" Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1"
                CornerRadius="8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Başlık + durum -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="ChessGUI" Style="{StaticResource HeaderText}" FontSize="20"/>
                    <TextBlock Text="{Binding SideToMoveText}" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding OpeningText}" Style="{StaticResource MutedText}" Margin="0,3,0,0"
                               Visibility="{Binding OpeningText, Converter={StaticResource EmptyToCollapsed}}"/>
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}" Margin="0,3,0,12"/>
                </StackPanel>

                <!-- Araç çubukları -->
                <StackPanel Grid.Row="1">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Aç" Command="{Binding OpenPgnCommand}" Style="{StaticResource ToolButton}"/>
                        <Button Content="Kaydet" Command="{Binding SavePgnCommand}" Style="{StaticResource ToolButton}"/>
                        <Button Content="Yapıştır" Command="{Binding PastePgnCommand}" Style="{StaticResource ToolButton}"/>
                        <Button Content="Kopyala" Command="{Binding CopyPgnCommand}" Style="{StaticResource ToolButton}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="⏮" Command="{Binding StartCommand}" Style="{StaticResource ToolButton}"/>
                        <Button Content="◀" Command="{Binding BackCommand}" Style="{StaticResource ToolButton}"/>
                        <Button Content="▶" Command="{Binding ForwardCommand}" Style="{StaticResource ToolButton}"/>
                        <Button Content="⏭" Command="{Binding EndCommand}" Style="{StaticResource ToolButton}"/>
                        <Button Content="Çevir" Command="{Binding FlipCommand}" Style="{StaticResource ToolButton}" Margin="12,0,6,0"/>
                        <Button Content="Sıfırla" Command="{Binding ResetAnalysisCommand}" Style="{StaticResource ToolButton}"/>
                    </StackPanel>
                    <Border Height="1" Background="{DynamicResource PanelBorder}" Margin="0,12,0,0"/>
                </StackPanel>

                <!-- Açılış kitabı (kendi veritabanımızdan) -->
                <StackPanel Grid.Row="2" Margin="0,10,0,0" Visibility="{Binding Book.HasEntries, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="AÇILIŞ KİTABI" Style="{StaticResource MutedText}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Book.StatusText}" Style="{StaticResource MutedText}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding Book.Entries}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,6,6" Padding="7,4" CornerRadius="4"
                                        Background="#2C2C32" Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.Book.PlayMoveCommand,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding San}" FontFamily="Consolas" FontWeight="Bold"
                                                   FontSize="12.5" Foreground="{DynamicResource ForegroundBrush}"/>
                                        <TextBlock Text="{Binding ShareText}" FontFamily="Consolas" FontSize="11"
                                                   Foreground="{DynamicResource AccentBrush}" Margin="6,0,0,0"/>
                                        <TextBlock Text="{Binding GamesText}" FontFamily="Consolas" FontSize="11"
                                                   Style="{StaticResource MutedText}" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Height="1" Background="{DynamicResource PanelBorder}" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Hamle listesi -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,10,0,10">
                    <ItemsControl ItemsSource="{Binding MoveList.Tokens}"
                                  ItemTemplate="{StaticResource MoveTokenTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Motor / analiz -->
                <StackPanel Grid.Row="4">
                    <Border Height="1" Background="{DynamicResource PanelBorder}" Margin="0,0,0,12"/>
                    <TextBlock Text="MOTOR" Style="{StaticResource MutedText}" FontWeight="Bold" Margin="0,0,0,6"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding Engine.Engines}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding Engine.SelectedEngine}"
                                  MinHeight="30" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="+ Ekle" Command="{Binding LoadEngineCommand}"
                                Margin="8,0,0,0" Padding="10,6"/>
                    </Grid>

                    <Grid Margin="0,0,0,8" Visibility="{Binding Engine.SupportsSyzygy, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   Style="{StaticResource MutedText}">
                            <Run Text="Syzygy:"/>
                            <Run Text="{Binding Engine.SyzygyPath, Mode=OneWay}"/>
                        </TextBlock>
                        <Button Grid.Column="1" Content="Klasör…" Command="{Binding Engine.BrowseSyzygyPathCommand}"
                                Margin="8,0,0,0" Padding="10,6"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding Engine.ToggleAnalysisCommand}"
                                IsEnabled="{Binding Engine.EngineLoaded}" Margin="0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Content" Value="▶  Analizi başlat"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Engine.IsAnalyzing}" Value="True">
                                            <Setter Property="Content" Value="■  Analizi durdur"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="PV" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox Width="52" ItemsSource="{Binding Engine.MultiPvOptions}"
                                      SelectedItem="{Binding Engine.MultiPv}" MinHeight="30"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,2,0,8">
                        <TextBlock Text="{Binding Engine.DepthText}" FontFamily="Consolas" FontSize="13"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,14,0"/>
                        <TextBlock Text="{Binding Engine.NpsText}" FontFamily="Consolas" FontSize="13"
                                   Style="{StaticResource MutedText}" Margin="0,0,14,0"/>
                        <TextBlock Text="{Binding Engine.TbHitsText}" FontFamily="Consolas" FontSize="13"
                                   Foreground="#7FB07F"
                                   Visibility="{Binding Engine.TbHitsText, Converter={StaticResource EmptyToCollapsed}}"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Engine.Lines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding EvalText}" FontFamily="Consolas" FontWeight="Bold"
                                               FontSize="13" Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Moves}" FontFamily="Consolas" FontSize="12.5"
                                               Foreground="{DynamicResource MutedForeground}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- FEN -->
                <StackPanel Grid.Row="5">
                    <TextBlock Text="FEN" Style="{StaticResource MutedText}" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding Fen, Mode=OneWay}" IsReadOnly="True"
                             TextWrapping="Wrap" Background="#1B1B1F"
                             Foreground="{DynamicResource MutedForeground}"
                             BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1"
                             Padding="8" FontFamily="Consolas" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
